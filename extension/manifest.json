{
    "manifest_version": 3,
    "name": "StreamVault",
    "description": "Ad blocker, video chat & Watch Together for StreamVault",
    "version": "2.0.0",
    "permissions": [
        "storage",
        "activeTab",
        "tabs",
        "cookies",
        "declarativeNetRequest",
        "notifications",
        "alarms"
    ],
    "optional_permissions": [
        "history"
    ],
    "host_permissions": [
        "https://streamvault.live/*",
        "https://www.streamvault.live/*",
        "https://streamvault.in/*",
        "https://www.streamvault.in/*",
        "http://localhost:5000/*",
        "http://localhost:3000/*",
        "http://localhost:5173/*",
        "https://www.imdb.com/*",
        "https://www.themoviedb.org/*",
        "https://myanimelist.net/*"
    ],
    "content_scripts": [
        {
            "matches": [
                "https://streamvault.live/*",
                "https://www.streamvault.live/*",
                "https://streamvault.in/*",
                "https://www.streamvault.in/*",
                "http://localhost:5000/*",
                "http://localhost:3000/*",
                "http://localhost:5173/*"
            ],
            "js": [
                "content-scripts/ad-blocker.js",
                "content-scripts/streamvault-bridge.js"
            ],
            "run_at": "document_start"
        },
        {
            "matches": [
                "https://www.imdb.com/title/*",
                "https://www.themoviedb.org/movie/*",
                "https://www.themoviedb.org/tv/*",
                "https://myanimelist.net/anime/*",
                "https://www.google.com/search*",
                "https://www.google.co.in/search*"
            ],
            "js": [
                "content-scripts/external-integrations.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "commands": {
        "quick-search": {
            "suggested_key": {
                "default": "Ctrl+Shift+S",
                "mac": "Command+Shift+S"
            },
            "description": "Quick search StreamVault"
        },
        "open-watchlist": {
            "suggested_key": {
                "default": "Ctrl+Shift+W"
            },
            "description": "Open watchlist"
        }
    },
    "declarative_net_request": {
        "rule_resources": [
            {
                "id": "ad_rules",
                "enabled": true,
                "path": "rules/ad-rules.json"
            }
        ]
    }
}